# ---------------------------------------------------------------------------
# AegisScan configuration. Copy to ".env" and adjust. Every value has a safe
# default, so the app runs with an EMPTY or absent .env file out of the box.
# ---------------------------------------------------------------------------

# App
AEGIS_ENV=development                 # development | staging | production
AEGIS_DEBUG=true

# Security. CHANGE THIS in any non-local deployment. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AEGIS_SECRET_KEY=dev-insecure-change-me
AEGIS_ACCESS_TOKEN_TTL_MINUTES=1440

# Database. Default is a local SQLite file = zero external services.
# For Postgres (e.g. Supabase/Railway) use:
#   AEGIS_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
AEGIS_DATABASE_URL=sqlite:///./aegisscan.db

# CORS. Regex is used so every Vercel-style preview hostname matches with one
# rule (the fix for PostureScan's "CORS rejected every preview URL" problem).
AEGIS_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$|^https://([a-z0-9-]+\.)*vercel\.app$

# Scan engine
AEGIS_SCAN_TIMEOUT_SECONDS=10         # per-probe network timeout
AEGIS_SCAN_TOTAL_BUDGET_SECONDS=25    # hard ceiling for a whole scan
AEGIS_ALLOW_PRIVATE_TARGETS=false     # SSRF guard. NEVER set true in production.
AEGIS_RATE_LIMIT_PER_MINUTE=20        # per-IP scan submissions

# Public dashboard hostname masking. Comma-separated allowlist of public
# benchmarks that are safe to show un-masked.
AEGIS_PUBLIC_BENCHMARKS=github.com,stripe.com,cloudflare.com,google.com,mozilla.org

# Observability (optional). Leave blank to disable.
AEGIS_SENTRY_DSN=
